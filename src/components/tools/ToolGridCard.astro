---
import { Card, CardContent } from "@/components/starwind/card";
import { getCategory } from "@/lib/categories";

interface Props {
  tool: {
    slug: string;
    title: string;
    description: string;
    icon: string;
    category: string;
  };
}

const { tool } = Astro.props;

const category = getCategory(tool.category);
---

<a href={`/tools/${tool.slug}`}>
  <Card class="h-full transition-all hover:-translate-y-1 hover:border-primary hover:shadow-md">
    <CardContent class="p-6">
      <div class="text-4xl">
        {tool.icon}
      </div>

      <h3 class="mt-5 text-xl font-semibold">
        {tool.title}
      </h3>

      <p class="mt-2 text-sm text-muted-foreground">
        {tool.description}
      </p>

      {category && (
        <span class="mt-5 inline-flex items-center gap-2 rounded-full bg-muted px-3 py-1 text-xs font-medium">
          <span>{category.icon}</span>
          <span>{category.name}</span>
        </span>
      )}
    </CardContent>
  </Card>
</a>