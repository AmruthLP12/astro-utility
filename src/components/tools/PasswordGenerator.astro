---
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import { Checkbox } from "@/components/starwind/checkbox";
import { Slider } from "@/components/starwind/slider";
---

<div class="space-y-8">

  <!-- Password Output -->
  <div class="space-y-2">

    <Label for="password">
      Generated Password
    </Label>

    <div class="flex gap-2">

      <Input
        id="password"
        readonly
        value=""
        class="font-mono text-lg"
      />

      <Button id="copyBtn" variant="outline">
        Copy
      </Button>

    </div>

  </div>

  <!-- Length -->

  <div class="space-y-4">

    <div class="flex items-center justify-between">

      <Label for="length">
        Password Length
      </Label>

      <Input
        id="lengthInput"
        type="number"
        value="8"
        min="4"
        max="80"
        class="w-20"
      />

    </div>

    <input
  id="lengthSlider"
  type="range"
  min="4"
  max="80"
  step="1"
  value="8"
  class="accent-primary w-full"
/>

  </div>

  <!-- Options -->

  <div class="grid gap-4 md:grid-cols-2">

    <Label class="flex items-center gap-3">

      <Checkbox id="uppercase" checked />

      Uppercase Letters

    </Label>

    <Label class="flex items-center gap-3">

      <Checkbox id="lowercase" checked />

      Lowercase Letters

    </Label>

    <Label class="flex items-center gap-3">

      <Checkbox id="numbers" checked />

      Numbers

    </Label>

    <Label class="flex items-center gap-3">

      <Checkbox id="symbols" checked />

      Symbols

    </Label>

  </div>

  <!-- Strength -->

  <div class="space-y-2">

    <div class="flex justify-between text-sm">

      <span>Password Strength</span>

      <span id="strengthText">
        Strong
      </span>

    </div>

    <div class="h-2 overflow-hidden rounded-full bg-muted">

      <div
        id="strengthBar"
        class="h-full w-3/4 rounded-full bg-green-500"
      />

    </div>

  </div>

  <!-- Generate -->

  <Button
    id="generateBtn"
    class="w-full"
  >
    Generate Password
  </Button>

</div>

<script>
  import "@/scripts/password-generator";
</script>