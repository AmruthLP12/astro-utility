---
import { Button } from "@/components/starwind/button";
import { Checkbox } from "@/components/starwind/checkbox";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
---

<div class="space-y-8">
  <div class="space-y-2">
    <Label for="word">Word or Phrase</Label>

    <Input
      id="word"
      placeholder="Enter a word..."
    />
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <Label class="flex items-center gap-3">
      <Checkbox id="numbers" checked />
      Add Numbers
    </Label>

    <Label class="flex items-center gap-3">
      <Checkbox id="symbols" checked />
      Add Symbols
    </Label>

    <Label class="flex items-center gap-3">
      <Checkbox id="caps" checked />
      Random Capitalization
    </Label>

    <Label class="flex items-center gap-3">
      <Checkbox id="prefix" />
      Add Prefix
    </Label>
  </div>

  <Button id="generateBtn" class="w-full">
    Generate Passwords
  </Button>

  <div id="results" class="grid gap-3"></div>
</div>

<script>
  import "src/scripts/word-to-password";
</script>