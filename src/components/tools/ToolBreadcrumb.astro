---
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from "@/components/starwind/breadcrumb";

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<Breadcrumb class="mb-8">
  <BreadcrumbList>

    {items.map((item, index) => (
      <>
        <BreadcrumbItem>

          {index === items.length - 1 ? (
            <BreadcrumbPage>
              {item.label}
            </BreadcrumbPage>
          ) : (
            <BreadcrumbLink href={item.href}>
              {item.label}
            </BreadcrumbLink>
          )}

        </BreadcrumbItem>

        {index !== items.length - 1 && (
          <BreadcrumbSeparator />
        )}
      </>
    ))}

  </BreadcrumbList>
</Breadcrumb>